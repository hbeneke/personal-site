---
import CVDownloadIcon from "@components/cv-download.astro";
import ScrollToTop from "@components/scroll-to-top.astro";
import BaseLayout from "@layouts/base-layout.astro";

import { calculateDuration } from "@utils/date";
import { getAllHonorsGroupByCategory } from "@utils/honor";
import { getAllWorkExperiences, getWorkExperienceYears } from "@utils/resume";
import { getAllSkills } from "@utils/skills";

import { siteConfig } from "@site-config";

const work_experience = await getAllWorkExperiences();
const years = await getWorkExperienceYears();
const skills = await getAllSkills();
const honors = await getAllHonorsGroupByCategory(true);
---

<BaseLayout
  title={`Resume · ${siteConfig.siteTitle}`}
  description={`${siteConfig.authorName} resume, a Senior ${siteConfig.jobTitle} specializing in Javascript and modern web technologies.`}
>
  <section>
    <header class="mb-8">
      <div
        class="flex flex-wrap items-center justify-between gap-3 mb-3 border-b border-gray-200 dark:border-gray-700 pb-2"
      >
        <h1 class="text-2xl font-semibold secondary">Enrique Quero</h1>
        <CVDownloadIcon />
      </div>
      <p class="text-xs text-gray-600 dark:text-gray-400">
        Senior {siteConfig.jobTitle} / Tech Lead
        <span class="mx-1">·</span>
        <span class="italic">"Never Stop Learning."</span>
      </p>
    </header>

    <section class="mb-10">
      <h2 class="text-xl font-medium mb-4 secondary">Summary</h2>
      <p class="text-xs leading-relaxed text-gray-600 dark:text-gray-400">
        Web developer with {calculateDuration(years.start, years.end)} of experience
        in web development, always looking for new challenges and projects that feed
        my motto of "Never Stop Learning."
      </p>
    </section>

    <section class="mb-10">
      <h2 class="text-xl font-medium mb-4 secondary">Work Experience</h2>
      <div class="space-y-5">
        {
          work_experience.map((experience) => (
            <article class="pb-5">
              <div class="flex flex-wrap items-baseline justify-between gap-x-3 mb-1">
                {experience.company_url ? (
                  <a
                    href={experience.company_url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-base secondary hover:secondary-hovered"
                  >
                    {experience.company}
                  </a>
                ) : (
                  <span class="text-base secondary">{experience.company}</span>
                )}
                <time class="text-xs text-gray-600 dark:text-gray-400 whitespace-nowrap">
                  {experience.start_date} – {experience.end_date}
                </time>
              </div>
              <div class="text-xs text-gray-600 dark:text-gray-400 mb-3">
                {experience.position}
                <span class="mx-1">·</span>
                {experience.location}
              </div>
              {experience.description && (
                <p class="text-xs mb-3">{experience.description}</p>
              )}
              {experience.responsibilities &&
                experience.responsibilities.length > 0 && (
                  <ul class="space-y-1">
                    {experience.responsibilities.map((responsibility) => (
                      <li class="text-xs flex gap-2">
                        <span class="secondary select-none">▹</span>
                        <span>{responsibility}</span>
                      </li>
                    ))}
                  </ul>
                )}
            </article>
          ))
        }
      </div>
    </section>

    <section class="mb-10">
      <h2 class="text-xl font-medium mb-4 secondary">Skills</h2>
      <div class="space-y-4">
        {
          skills.map((skill) => (
            <div>
              <div class="text-xs secondary mb-2">{skill.name}</div>
              <div class="flex flex-wrap gap-1.5">
                {skill.perks.map((perk) => (
                  <span class="text-xs px-1.5 py-0.5 rounded bg-gray-100 text-gray-600 dark:bg-gray-800 dark:text-gray-400">
                    {perk}
                  </span>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <section class="mb-10">
      <h2 class="text-xl font-medium mb-4 secondary">Honors & Awards</h2>
      <div class="space-y-6">
        {
          Object.entries(honors).map(([category, categoryHonors]) => (
            <div>
              <div class="text-xs secondary mb-2">{category}</div>
              <ul class="space-y-2">
                {categoryHonors.map((honor) => (
                  <li class="grid gap-x-3 gap-y-0.5 sm:grid-cols-[auto_1fr_auto] items-baseline">
                    <span class="text-xs font-mono text-gray-600 dark:text-gray-400 whitespace-nowrap">
                      {honor.year}
                    </span>
                    <span class="text-xs">{honor.title}</span>
                    <span class="text-xs italic text-gray-600 dark:text-gray-400">
                      {honor.location}
                    </span>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </section>
  </section>
  <ScrollToTop />
</BaseLayout>
