---
import "@styles/global.css";
import Notes from "@components/recent-notes.astro";
import SchemaMarkup from "@components/schema-markup.astro";
import SEO from "@components/seo.astro";
import Header from "@components/site-header.astro";
import { siteConfig } from "@site-config";
import Analytics from "@vercel/analytics/astro";
import SpeedInsights from "@vercel/speed-insights/astro";

interface Props {
  title: string;
  description: string;
  image?: string;
  article?: boolean;
  publishDate?: string;
  modifiedDate?: string;
  canonicalUrl?: URL | string;
  schemaType?: "WebSite" | "Person" | "BlogPosting" | "Article" | "BreadcrumbList";
  noindex?: boolean;
  nofollow?: boolean;
  author?: string;
  tags?: string[];
}

const {
  title,
  description,
  image,
  article,
  publishDate,
  modifiedDate,
  canonicalUrl,
  schemaType = "WebSite",
  noindex,
  nofollow,
  author,
  tags,
} = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <SEO
      title={title}
      description={description}
      image={image}
      article={article}
      publishDate={publishDate}
      modifiedDate={modifiedDate}
      canonicalUrl={canonicalUrl}
      noindex={noindex}
      nofollow={nofollow}
      author={author}
      tags={tags}
    />

    <SchemaMarkup
      type={schemaType}
      title={title}
      description={description}
      url={canonicalUrl?.toString()}
      image={image}
      publishDate={publishDate}
      modifiedDate={modifiedDate}
      tags={tags}
    />

    {
      import.meta.env.PROD && (
        <>
          <Analytics />
          <SpeedInsights />
        </>
      )
    }
  </head>
  <body
    class="flex mx-auto min-w-[350px] font-jetbrains min-h-screen max-w-3xl flex-col bg-bgColor px-4 pt-16 text-sm font-normal text-textColor antialiased sm:px-8"
  >
    <Header />
    <main id="main" class="flex-grow">
      <slot />
    </main>
    <site-footer
      nickname={siteConfig.nickname}
      year={siteConfig.copyrightYear}
      copyright="bugs"
      class="[--font:var(--font-jetbrains)] [--link:rgb(var(--primary))] [--link-hover:rgb(var(--primary-hovered))] [--accent:rgb(var(--secondary))]"
    >
    </site-footer>
    <Notes />

    <script>
      import "@hbeneke/parley";
    </script>
  </body>
</html>
